.log-card { padding: 30rpx !important; }
.formula-text { font-size: 26rpx; color: #8E8E93; margin-bottom: 16rpx; line-height: 1.5; font-family: monospace; }
.result-text { font-size: 32rpx; font-weight: 600; color: #000; text-align: right; }
.hl-num { font-size: 44rpx; font-weight: 800; font-family: monospace; margin: 0 10rpx; }
.hl-blue { color: #007AFF; }
.highlight-dark { background: #1C1C1E !important; color: #FFF; border: none; }
.macro-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #333; }
.macro-row:last-child { border-bottom: none; }
.m-label { font-size: 30rpx; color: #E5E5EA; }
.m-val { font-size: 44rpx; font-weight: 800; }
.hl-gold { color: #FFD60A; }
.desc-text { font-size: 28rpx; color: #333; line-height: 1.6; }