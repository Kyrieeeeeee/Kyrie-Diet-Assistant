.segment-control { display: flex; background: #E5E5EA; border-radius: 16rpx; padding: 6rpx; }
.seg-item { flex: 1; text-align: center; padding: 16rpx 0; font-size: 28rpx; font-weight: 600; color: #8E8E93; border-radius: 12rpx; }
.seg-item.active { background: #fff; color: #000; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05); }

.food-card { flex-direction: column; align-items: flex-start !important; }
.f-name { font-size: 34rpx; font-weight: 700; margin-bottom: 16rpx; }
.f-tags { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.tag { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; font-weight: 600; }
.tag.gray { background: #F2F2F7; color: #8E8E93; }
.tag.blue { background: #E5F1FF; color: #007AFF; }
.tag.orange { background: #FFF0E5; color: #FF9500; }
.f-actions { width: 100%; display: flex; justify-content: flex-end; border-top: 1px dashed #eee; padding-top: 16rpx; }
.action-btn { font-size: 28rpx; margin-left: 30rpx; font-weight: 600; }
.edit { color: #007AFF; }
.delete { color: #FF3B30; }

/* 弹窗样式 */
.modal-mask { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999; display: flex; justify-content: center; align-items: center; }
.modal-content { width: 80%; padding: 40rpx; }
.modal-title { font-size: 36rpx; font-weight: 700; text-align: center; margin-bottom: 30rpx; }
.m-input-group { margin-bottom: 20rpx; }
.m-label { font-size: 26rpx; color: #8E8E93; margin-bottom: 8rpx; display: block; }
.m-input { background: #F2F2F7; padding: 20rpx; border-radius: 16rpx; font-size: 30rpx; }
.modal-btns { display: flex; justify-content: space-between; margin-top: 40rpx; }
.m-btn { flex: 1; font-size: 30rpx; font-weight: 600; border-radius: 16rpx; margin: 0 10rpx; }
.m-btn.cancel { background: #F2F2F7; color: #8E8E93; }
.m-btn.confirm { background: #007AFF; color: #fff; }
.ghost-btn { background: transparent; color: #007AFF; border: 2rpx solid #007AFF; }