<view class="page-container">
  <view class="large-title">今日状态</view>

  <view class="ios-card profile-summary-card" bindtap="goToProfile" style="display:flex; justify-content:space-between; align-items:center; padding:30rpx 40rpx; background:#fff; margin-bottom:20rpx; border-radius:32rpx;">
    <view class="p-left" style="display:flex; align-items:center;">
      <view class="p-icon" style="font-size:70rpx; background:#F2F2F7; width:100rpx; height:100rpx; border-radius:50%; text-align:center; line-height:100rpx; margin-right:25rpx;">{{profile.isMale ? '👨' : '👩'}}</view>
      <view class="p-labels" style="display:flex; flex-direction:column;">
        <text class="p-main-title" style="font-size:34rpx; font-weight:700; color:#000;">我的身体档案</text>
        <text class="p-sub-title" style="font-size:26rpx; color:#8E8E93; margin-top:4rpx;">{{profile.isMale ? '男性' : '女性'}} · {{profile.age}}岁 · {{profile.height}}cm</text>
      </view>
    </view>
    <view class="p-right"><text class="modify-btn" style="font-size:28rpx; color:#C7C7CC;">修改 〉</text></view>
  </view>

  <view class="section-header">核心打卡数据</view>
  <view class="list-group">
    <view class="list-item">
      <text class="item-label" style="font-weight: 700;">今日空腹体重 (kg)</text>
      <input class="ghost-input" style="font-size:44rpx; font-weight:800; color:#007AFF;" type="digit" value="{{weight}}" bindinput="inputWeight" placeholder="0.0" />
    </view>
    <view class="list-item">
      <text class="item-label">当前阶段</text>
      <picker bindchange="changeGoal" range="{{['减脂期 (制造缺口)', '增肌期 (制造盈余)']}}">
        <text class="val-text">{{goalIdx==0 ? '减脂' : '增肌'}} 〉</text>
      </picker>
    </view>
  </view>

  <view class="list-group">
    <view class="list-item">
      <text class="item-label">包含力量训练</text>
      <switch bindchange="toggleTrain" checked="{{isTrain}}" color="#007AFF" />
    </view>
    <view class="list-item" wx:if="{{isTrain}}">
      <text class="item-label">训练时段</text>
      <picker bindchange="changeTime" range="{{times}}">
        <text class="val-text blue">{{times[timeIdx]}} 〉</text>
      </picker>
    </view>
    
    <view class="list-item" style="border-top: 1rpx solid #E5E5EA;">
      <text class="item-label">包含有氧训练</text>
      <switch bindchange="toggleAerobic" checked="{{isAerobic}}" color="#34C759" />
    </view>
    <block wx:if="{{isAerobic}}">
      <view class="list-item">
        <text class="item-label">有氧项目</text>
        <picker bindchange="changeAerobic" range="{{aerobicOptions}}" range-key="name">
          <text class="val-text blue">{{aerobicOptions[aerobicIdx].name}} 〉</text>
        </picker>
      </view>
      <view class="list-item">
        <text class="item-label">当日运动时长(小时)</text>
        <input class="ghost-input" type="digit" value="{{aerobicHours}}" bindinput="inputAerobicHours" placeholder="如: 0.5 或 1.0" />
      </view>
    </block>
  </view>

  <view class="section-header">今日食材调用</view>
  <view class="list-group">
    <view class="list-item">
      <text class="item-label" style="font-weight:700;">开启三餐独立精细化配置</text>
      <switch bindchange="toggleAdvanced" checked="{{isAdvanced}}" color="#007AFF" />
    </view>
    
    <block wx:if="{{!isAdvanced}}">
      <view class="list-item">
        <text class="item-label">全天主碳水</text>
        <picker bindchange="pickCarb" range="{{carbList}}" range-key="name"><text class="val-text">{{carbList[carbIdx].name}} 〉</text></picker>
      </view>
      <view class="list-item">
        <text class="item-label">全天主蛋白</text>
        <picker bindchange="pickPro" range="{{proteinList}}" range-key="name"><text class="val-text">{{proteinList[proIdx].name}} 〉</text></picker>
      </view>
    </block>

    <block wx:if="{{isAdvanced}}">
      <view class="section-header" style="margin-top:20rpx; font-size:24rpx;">🌅 早餐食材</view>
      <view class="list-item">
        <text class="item-label">碳水来源</text>
        <picker bindchange="pickBreakCarb" range="{{carbList}}" range-key="name"><text class="val-text">{{carbList[breakCarbIdx].name}} 〉</text></picker>
      </view>
      <view class="list-item">
        <text class="item-label">蛋白来源</text>
        <picker bindchange="pickBreakPro" range="{{proteinList}}" range-key="name"><text class="val-text">{{proteinList[breakProIdx].name}} 〉</text></picker>
      </view>

      <view class="section-header" style="margin-top:20rpx; font-size:24rpx;">🍱 午餐食材</view>
      <view class="list-item">
        <text class="item-label">碳水来源</text>
        <picker bindchange="pickLunchCarb" range="{{carbList}}" range-key="name"><text class="val-text">{{carbList[lunchCarbIdx].name}} 〉</text></picker>
      </view>
      <view class="list-item">
        <text class="item-label">蛋白来源</text>
        <picker bindchange="pickLunchPro" range="{{proteinList}}" range-key="name"><text class="val-text">{{proteinList[lunchProIdx].name}} 〉</text></picker>
      </view>

      <view class="section-header" style="margin-top:20rpx; font-size:24rpx;">🌙 晚餐食材</view>
      <view class="list-item">
        <text class="item-label">碳水来源</text>
        <picker bindchange="pickDinnerCarb" range="{{carbList}}" range-key="name"><text class="val-text">{{carbList[dinnerCarbIdx].name}} 〉</text></picker>
      </view>
      <view class="list-item">
        <text class="item-label">蛋白来源</text>
        <picker bindchange="pickDinnerPro" range="{{proteinList}}" range-key="name"><text class="val-text">{{proteinList[dinnerProIdx].name}} 〉</text></picker>
      </view>
    </block>

    <view class="list-item" bindtap="goToManageFood">
      <text class="item-label blue">⚙️ 管理食材库 (编辑 / 加单位 / 删除)</text>
    </view>
  </view>

  <button class="primary-btn" bindtap="calculate">生成今日精确食谱</button>
</view>